---
import "../styles/global.css";
import { formatDateLong } from "../utils/format";
import Icon from "../components/Icon.astro";

interface Props {
    title: string;
    description?: string;
    footer?: string;
    date?: string;
    ogType?: "website" | "article";
    ogTitle?: string;
    ogDescription?: string;
}

const {
    title,
    description = "Athanor — distillation quotidienne de veille technique.",
    footer,
    date,
    ogType = "website",
    ogTitle,
    ogDescription,
} = Astro.props;

const socialTitle = ogTitle ?? title;
const socialDescription = ogDescription ?? description;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(`${base}og-image.png`, Astro.site).href;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
        <link rel="icon" sizes="any" href={`${base}favicon.ico`} />
        <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
        <link rel="alternate" type="application/rss+xml" title="Athanor" href={`${base}rss.xml`} />

        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Athanor" />
        <meta property="og:locale" content="fr_FR" />
        <meta property="og:title" content={socialTitle} />
        <meta property="og:description" content={socialDescription} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="Athanor" />
        {ogType === "article" && date && (
            <meta property="article:published_time" content={date} />
        )}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={socialTitle} />
        <meta name="twitter:description" content={socialDescription} />
        <meta name="twitter:image" content={ogImage} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Montserrat:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
    </head>
    <body>
        <div class="wrap">
            <nav class="site-nav">
                <div class="brand-wrap">
                    <a href={base} class="brand">Athanor</a>
                    {
                        date && (
                            <span class="brand-date">
                                · {formatDateLong(date)}
                            </span>
                        )
                    }
                </div>
                <div class="links">
                    <a href={base}>
                        <Icon name="flame" />
                        <span>Dernier</span>
                    </a>
                    <a href={`${base}archive/`}>
                        <Icon name="archive" />
                        <span>Archive</span>
                    </a>
                    <a href={`${base}rss.xml`}>
                        <Icon name="rss" />
                        <span>RSS</span>
                    </a>
                </div>
            </nav>
            <slot />
            <footer class="site-footer">
                Athanor is made with ♥️ by <a href="https://y0no.fr">y0no</a>
            </footer>
        </div>
    </body>
</html>

---
import Masthead from "./Masthead.astro";
import Category from "./Category.astro";
import CategoryNav from "./CategoryNav.astro";
import Appendix from "./Appendix.astro";

interface Props {
  digest: any;
}

const { digest } = Astro.props;

const navCategories = digest.categories.map((c: any) => ({ slug: c.slug, name: c.name }));
---
<Masthead headline={digest.headline} />
{digest.alert && <div class="alert" set:html={digest.alert} />}
<CategoryNav categories={navCategories} />
{digest.categories.map((cat: any) => <Category {...cat} />)}
<Appendix items={digest.appendix ?? []} />

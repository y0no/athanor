---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DigestView from "../../components/DigestView.astro";
import { formatDateLong } from "../../utils/format";

export async function getStaticPaths() {
  const all = await getCollection("digests");
  const sorted = all.sort((a, b) => b.data.date.localeCompare(a.data.date));
  const archive = sorted.slice(0, 30).map((e) => ({
    date: e.data.date,
    headline: e.data.headline,
  }));

  return sorted.map((entry) => ({
    params: { date: entry.data.date },
    props: { digest: entry.data, archive },
  }));
}

const { digest, archive } = Astro.props;
const pageTitle = digest.title_tag || `Athanor — ${formatDateLong(digest.date)}`;
---
<BaseLayout title={pageTitle} description={digest.headline} footer={digest.footer} date={digest.date}>
  <DigestView digest={digest} archive={archive} />
</BaseLayout>

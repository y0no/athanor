---
import { formatArchiveLabel } from "../utils/format";

interface Entry {
  date: string;
  headline: string;
}

interface Props {
  entries: Entry[];
  currentDate?: string;
}

const { entries, currentDate } = Astro.props;
const base = import.meta.env.BASE_URL;
---
{entries.length > 1 && (
  <section class="archive-strip">
    <h2>30 derniers jours</h2>
    <ul class="days">
      {entries.map((e) => (
        <li>
          <a
            href={`${base}digest/${e.date}/`}
            class={e.date === currentDate ? "current" : ""}
            title={e.headline}
          >
            {formatArchiveLabel(e.date)}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
